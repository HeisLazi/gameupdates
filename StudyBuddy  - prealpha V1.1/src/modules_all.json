{
  "modules": [
    {
      "id": "tutorial",
      "name": "Tutorial — How to Play",
      "description": "Learn how StudyBuddy works. Answer questions about the game itself.",
      "tags": [
        "tutorial",
        "game"
      ],
      "levels": [
        {
          "id": "tut_basics",
          "name": "Game Basics",
          "concepts": [
            {
              "id": "tut_modes",
              "name": "Study vs Arena Mode",
              "definition": "StudyBuddy has two modes: Study (calm, notes-first, no penalties) and Arena (combat, drops, real stakes). The same questions live in both — Arena just adds combat on top.",
              "questions": [
                {
                  "id": "tut_modes_1",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "Which mode never punishes wrong answers?",
                  "choices": [
                    "Arena",
                    "Study",
                    "Cram",
                    "Raid"
                  ],
                  "answer": "Study",
                  "explanation": "Study Mode is for learning — wrong answers cost nothing. Arena adds combat."
                },
                {
                  "id": "tut_modes_2",
                  "type": "tf",
                  "difficulty": "easy",
                  "marks": 1,
                  "prompt": "Arena Mode and Study Mode use the same question pool.",
                  "answer": true,
                  "explanation": "Same questions, different framing."
                },
                {
                  "id": "tut_modes_3",
                  "type": "define",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "Define: Cram Mode",
                  "answer": "A 10-minute wave-survival mode where you fight enemies until a boss spawns at wave 10 or 10:00.",
                  "keywords": [
                    "10 minutes",
                    "wave",
                    "boss",
                    "survival"
                  ]
                }
              ]
            },
            {
              "id": "tut_combat",
              "name": "Combat Loop",
              "definition": "Pick an action (weapon ability or guard), answer a question. Correct = damage. Wrong = enemy hits you back. Streak builds your damage. Same ability twice in a row = -25% damage.",
              "questions": [
                {
                  "id": "tut_combat_1",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "What happens when you answer a question correctly in combat?",
                  "choices": [
                    "Enemy heals",
                    "You deal damage to the enemy",
                    "You skip a turn",
                    "You lose insight"
                  ],
                  "answer": "You deal damage to the enemy"
                },
                {
                  "id": "tut_combat_2",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "What is the penalty for using the same ability twice in a row?",
                  "choices": [
                    "Cooldown +1",
                    "Damage -25%",
                    "Lose 5 HP",
                    "Streak resets"
                  ],
                  "answer": "Damage -25%"
                },
                {
                  "id": "tut_combat_3",
                  "type": "tf",
                  "difficulty": "easy",
                  "marks": 1,
                  "prompt": "Building a streak (consecutive correct answers) increases your damage.",
                  "answer": true
                },
                {
                  "id": "tut_combat_4",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "Which keys swap abilities mid-question?",
                  "choices": [
                    "Arrow keys",
                    "1-9 number keys",
                    "WASD",
                    "F1-F9"
                  ],
                  "answer": "1-9 number keys"
                }
              ]
            },
            {
              "id": "tut_builds",
              "name": "Building Your Character",
              "definition": "7 weapons, 30+ augments (socketed in the Armory), a skill tree of passives + actives, and a pet companion. Upgrade augments at the Forge. Trade for power at the Forbidden Exchange.",
              "questions": [
                {
                  "id": "tut_builds_1",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "Where do you slot augments to gain their bonuses?",
                  "choices": [
                    "The Forge",
                    "Armory weapon sockets",
                    "The Library",
                    "Cram Mode"
                  ],
                  "answer": "Armory weapon sockets"
                },
                {
                  "id": "tut_builds_2",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "How many sockets do you start with?",
                  "choices": [
                    "0",
                    "2",
                    "4",
                    "6"
                  ],
                  "answer": "2",
                  "explanation": "You begin with 2 sockets. +1 every 5 player levels, capped at 6."
                },
                {
                  "id": "tut_builds_3",
                  "type": "tf",
                  "difficulty": "easy",
                  "marks": 1,
                  "prompt": "Tree skill passives only work if they are in your hotbar.",
                  "answer": false,
                  "explanation": "Passives auto-activate from unlocked tree skills regardless of hotbar."
                },
                {
                  "id": "tut_builds_4",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "What does the Forge let you do?",
                  "choices": [
                    "Recruit pets",
                    "Shard duplicates, craft new augments, upgrade existing ones",
                    "Reset prestige",
                    "Skip levels"
                  ],
                  "answer": "Shard duplicates, craft new augments, upgrade existing ones"
                }
              ]
            }
          ]
        }
      ],
      "examTemplate": {
        "durationMin": 15,
        "totalMarks": 20,
        "composition": [
          {
            "type": "mcq",
            "count": 5,
            "marks": 2
          },
          {
            "type": "tf",
            "count": 5,
            "marks": 1
          },
          {
            "type": "define",
            "count": 2,
            "marks": 2
          }
        ]
      }
    },
    {
      "id": "maths_basic",
      "name": "Basic Maths",
      "description": "Arithmetic, fractions, percentages, and intro algebra.",
      "tags": [
        "stock",
        "maths"
      ],
      "levels": [
        {
          "id": "mb_arith",
          "name": "Arithmetic",
          "concepts": [
            {
              "id": "mb_order_ops",
              "name": "Order of Operations",
              "definition": "BODMAS / PEMDAS: Brackets/Parentheses, Orders/Exponents, Division+Multiplication (left to right), Addition+Subtraction (left to right).",
              "questions": [
                {
                  "id": "mb_oo_1",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "What is 2 + 3 × 4?",
                  "choices": [
                    "20",
                    "14",
                    "11",
                    "24"
                  ],
                  "answer": "14",
                  "explanation": "Multiplication before addition: 3×4=12, then 2+12=14."
                },
                {
                  "id": "mb_oo_2",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "What is (8 + 2) × 3?",
                  "choices": [
                    "14",
                    "24",
                    "30",
                    "32"
                  ],
                  "answer": "30"
                },
                {
                  "id": "mb_oo_3",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "What is 10 - 6 ÷ 2?",
                  "choices": [
                    "2",
                    "7",
                    "4",
                    "5"
                  ],
                  "answer": "7",
                  "explanation": "Division before subtraction: 6÷2=3, then 10-3=7."
                },
                {
                  "id": "mb_oo_4",
                  "type": "tf",
                  "difficulty": "easy",
                  "marks": 1,
                  "prompt": "In 5 × 2 + 3, you add first.",
                  "answer": false
                }
              ]
            },
            {
              "id": "mb_fractions",
              "name": "Fractions",
              "definition": "A fraction a/b represents a parts of a whole divided into b equal pieces. To add: get a common denominator. To multiply: multiply numerators and denominators.",
              "questions": [
                {
                  "id": "mb_fr_1",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "What is 1/2 + 1/4?",
                  "choices": [
                    "1/6",
                    "2/6",
                    "3/4",
                    "1/8"
                  ],
                  "answer": "3/4",
                  "explanation": "Common denominator 4: 1/2 = 2/4. So 2/4 + 1/4 = 3/4."
                },
                {
                  "id": "mb_fr_2",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "What is 2/3 × 3/4?",
                  "choices": [
                    "5/7",
                    "6/12",
                    "1/2",
                    "6/7"
                  ],
                  "answer": "1/2",
                  "explanation": "2×3=6, 3×4=12. 6/12 simplifies to 1/2."
                },
                {
                  "id": "mb_fr_3",
                  "type": "tf",
                  "difficulty": "easy",
                  "marks": 1,
                  "prompt": "To add fractions you must have the same denominator.",
                  "answer": true
                }
              ]
            },
            {
              "id": "mb_pct",
              "name": "Percentages",
              "definition": "Percent means \"per hundred\". 25% = 25/100 = 0.25. To find X% of Y, multiply Y by X/100.",
              "questions": [
                {
                  "id": "mb_pct_1",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "What is 20% of 80?",
                  "choices": [
                    "8",
                    "16",
                    "20",
                    "40"
                  ],
                  "answer": "16"
                },
                {
                  "id": "mb_pct_2",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "A shirt costs $50 and is on 30% off. What is the sale price?",
                  "choices": [
                    "$15",
                    "$20",
                    "$35",
                    "$45"
                  ],
                  "answer": "$35",
                  "explanation": "30% of 50 = 15. 50 - 15 = 35."
                },
                {
                  "id": "mb_pct_3",
                  "type": "tf",
                  "difficulty": "easy",
                  "marks": 1,
                  "prompt": "50% is the same as 1/2.",
                  "answer": true
                }
              ]
            }
          ]
        },
        {
          "id": "mb_algebra",
          "name": "Intro Algebra",
          "concepts": [
            {
              "id": "mb_solve_linear",
              "name": "Solving Linear Equations",
              "definition": "A linear equation in one variable has the form ax + b = c. Solve by isolating x using inverse operations on both sides.",
              "questions": [
                {
                  "id": "mb_lin_1",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "Solve: 2x + 3 = 11",
                  "choices": [
                    "x = 4",
                    "x = 5",
                    "x = 7",
                    "x = 8"
                  ],
                  "answer": "x = 4",
                  "explanation": "Subtract 3: 2x = 8. Divide by 2: x = 4."
                },
                {
                  "id": "mb_lin_2",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "Solve: 3x - 6 = 9",
                  "choices": [
                    "x = 1",
                    "x = 3",
                    "x = 5",
                    "x = 15"
                  ],
                  "answer": "x = 5"
                },
                {
                  "id": "mb_lin_3",
                  "type": "define",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "Define: linear equation",
                  "answer": "An equation where each variable appears only to the first power and is not multiplied by another variable.",
                  "keywords": [
                    "first",
                    "power",
                    "variable"
                  ]
                }
              ]
            },
            {
              "id": "mb_substitution",
              "name": "Substitution",
              "definition": "When given the value of a variable, replace each occurrence with that value to evaluate the expression.",
              "questions": [
                {
                  "id": "mb_sub_1",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "If x = 3, what is 2x + 5?",
                  "choices": [
                    "8",
                    "11",
                    "13",
                    "15"
                  ],
                  "answer": "11",
                  "explanation": "2(3) + 5 = 6 + 5 = 11."
                },
                {
                  "id": "mb_sub_2",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "If a = 4 and b = 2, what is a² - b?",
                  "choices": [
                    "10",
                    "12",
                    "14",
                    "6"
                  ],
                  "answer": "14",
                  "explanation": "4² = 16. 16 - 2 = 14."
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "english_basic",
      "name": "English",
      "description": "Vocabulary, grammar, and basic comprehension.",
      "tags": [
        "stock",
        "english"
      ],
      "levels": [
        {
          "id": "en_vocab",
          "name": "Vocabulary",
          "concepts": [
            {
              "id": "en_synonyms",
              "name": "Synonyms",
              "definition": "Words with similar meanings. \"Big\" and \"large\" are synonyms. They can usually be swapped without changing the meaning much.",
              "questions": [
                {
                  "id": "en_syn_1",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "Which is a synonym for \"happy\"?",
                  "choices": [
                    "sad",
                    "angry",
                    "joyful",
                    "tired"
                  ],
                  "answer": "joyful"
                },
                {
                  "id": "en_syn_2",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "Which is a synonym for \"fast\"?",
                  "choices": [
                    "slow",
                    "quick",
                    "late",
                    "soft"
                  ],
                  "answer": "quick"
                },
                {
                  "id": "en_syn_3",
                  "type": "tf",
                  "difficulty": "easy",
                  "marks": 1,
                  "prompt": "\"Begin\" and \"start\" are synonyms.",
                  "answer": true
                }
              ]
            },
            {
              "id": "en_antonyms",
              "name": "Antonyms",
              "definition": "Words with opposite meanings. \"Hot\" and \"cold\" are antonyms.",
              "questions": [
                {
                  "id": "en_ant_1",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "Which is an antonym for \"cold\"?",
                  "choices": [
                    "cool",
                    "warm",
                    "hot",
                    "icy"
                  ],
                  "answer": "hot"
                },
                {
                  "id": "en_ant_2",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "Which is an antonym for \"build\"?",
                  "choices": [
                    "create",
                    "destroy",
                    "make",
                    "design"
                  ],
                  "answer": "destroy"
                },
                {
                  "id": "en_ant_3",
                  "type": "tf",
                  "difficulty": "easy",
                  "marks": 1,
                  "prompt": "\"Empty\" is the antonym of \"full\".",
                  "answer": true
                }
              ]
            }
          ]
        },
        {
          "id": "en_grammar",
          "name": "Grammar",
          "concepts": [
            {
              "id": "en_parts_speech",
              "name": "Parts of Speech",
              "definition": "The categories of words: noun (person/place/thing), verb (action), adjective (describes a noun), adverb (describes a verb), pronoun, preposition, conjunction, interjection.",
              "questions": [
                {
                  "id": "en_pos_1",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "In \"She runs quickly\", what part of speech is \"quickly\"?",
                  "choices": [
                    "noun",
                    "verb",
                    "adjective",
                    "adverb"
                  ],
                  "answer": "adverb",
                  "explanation": "Adverbs describe verbs. \"Quickly\" describes how she runs."
                },
                {
                  "id": "en_pos_2",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "In \"The red car\", what part of speech is \"red\"?",
                  "choices": [
                    "noun",
                    "verb",
                    "adjective",
                    "adverb"
                  ],
                  "answer": "adjective"
                },
                {
                  "id": "en_pos_3",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "Which is a verb?",
                  "choices": [
                    "table",
                    "beautiful",
                    "jump",
                    "happily"
                  ],
                  "answer": "jump"
                }
              ]
            },
            {
              "id": "en_tense",
              "name": "Verb Tense",
              "definition": "Tense tells you when an action happened: past (already happened), present (happening now), future (will happen).",
              "questions": [
                {
                  "id": "en_t_1",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "What tense is \"I walked to school\"?",
                  "choices": [
                    "past",
                    "present",
                    "future",
                    "continuous"
                  ],
                  "answer": "past"
                },
                {
                  "id": "en_t_2",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "What tense is \"I will go tomorrow\"?",
                  "choices": [
                    "past",
                    "present",
                    "future",
                    "present perfect"
                  ],
                  "answer": "future"
                },
                {
                  "id": "en_t_3",
                  "type": "tf",
                  "difficulty": "easy",
                  "marks": 1,
                  "prompt": "\"She sings\" is in the present tense.",
                  "answer": true
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "science_basic",
      "name": "Science",
      "description": "Scientific method, basic physics, biology, and chemistry concepts.",
      "tags": [
        "stock",
        "science"
      ],
      "levels": [
        {
          "id": "sc_method",
          "name": "Scientific Method",
          "concepts": [
            {
              "id": "sc_steps",
              "name": "Steps of the Scientific Method",
              "definition": "Observation → Question → Hypothesis → Experiment → Analysis → Conclusion. The method is iterative and self-correcting.",
              "questions": [
                {
                  "id": "sc_st_1",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "What comes immediately after forming a hypothesis?",
                  "choices": [
                    "Conclusion",
                    "Observation",
                    "Experiment",
                    "Publication"
                  ],
                  "answer": "Experiment",
                  "explanation": "You test the hypothesis with an experiment."
                },
                {
                  "id": "sc_st_2",
                  "type": "define",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "Define: hypothesis",
                  "answer": "A testable, falsifiable proposed explanation for an observation.",
                  "keywords": [
                    "testable",
                    "explanation",
                    "observation"
                  ]
                },
                {
                  "id": "sc_st_3",
                  "type": "tf",
                  "difficulty": "easy",
                  "marks": 1,
                  "prompt": "A hypothesis must be testable and falsifiable.",
                  "answer": true
                }
              ]
            },
            {
              "id": "sc_variables",
              "name": "Variables",
              "definition": "Independent variable: what you change. Dependent variable: what you measure (changes in response). Controlled variables: what you keep constant.",
              "questions": [
                {
                  "id": "sc_v_1",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "In an experiment testing how light affects plant growth, what is the independent variable?",
                  "choices": [
                    "plant height",
                    "amount of light",
                    "soil type",
                    "water amount"
                  ],
                  "answer": "amount of light"
                },
                {
                  "id": "sc_v_2",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "What is the dependent variable in the same experiment?",
                  "choices": [
                    "amount of light",
                    "plant height",
                    "temperature",
                    "pot size"
                  ],
                  "answer": "plant height"
                }
              ]
            }
          ]
        },
        {
          "id": "sc_basics",
          "name": "Core Concepts",
          "concepts": [
            {
              "id": "sc_states_matter",
              "name": "States of Matter",
              "definition": "The three classical states are solid (fixed shape and volume), liquid (fixed volume, takes shape of container), and gas (no fixed shape or volume). Plasma is a fourth state at high energy.",
              "questions": [
                {
                  "id": "sc_sm_1",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "Which state has a fixed volume but no fixed shape?",
                  "choices": [
                    "solid",
                    "liquid",
                    "gas",
                    "plasma"
                  ],
                  "answer": "liquid"
                },
                {
                  "id": "sc_sm_2",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "What state of matter is steam?",
                  "choices": [
                    "solid",
                    "liquid",
                    "gas",
                    "plasma"
                  ],
                  "answer": "gas"
                },
                {
                  "id": "sc_sm_3",
                  "type": "tf",
                  "difficulty": "easy",
                  "marks": 1,
                  "prompt": "When ice melts to water, it goes from solid to liquid.",
                  "answer": true
                }
              ]
            },
            {
              "id": "sc_cell",
              "name": "The Cell",
              "definition": "The cell is the basic unit of life. All living things are made of cells. Cells have a membrane, cytoplasm, and (in eukaryotes) a nucleus.",
              "questions": [
                {
                  "id": "sc_c_1",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "What is the basic unit of life?",
                  "choices": [
                    "atom",
                    "molecule",
                    "cell",
                    "organ"
                  ],
                  "answer": "cell"
                },
                {
                  "id": "sc_c_2",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "Which cell structure contains DNA in eukaryotes?",
                  "choices": [
                    "mitochondria",
                    "nucleus",
                    "membrane",
                    "ribosome"
                  ],
                  "answer": "nucleus"
                },
                {
                  "id": "sc_c_3",
                  "type": "tf",
                  "difficulty": "easy",
                  "marks": 1,
                  "prompt": "Plant cells have cell walls; animal cells do not.",
                  "answer": true
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "cs_basic",
      "name": "Computer Science",
      "description": "Variables, control flow, data structures, and basic algorithm thinking.",
      "tags": [
        "stock",
        "cs"
      ],
      "levels": [
        {
          "id": "cs_basics",
          "name": "Programming Basics",
          "concepts": [
            {
              "id": "cs_variables",
              "name": "Variables",
              "definition": "A variable is a named storage location holding a value. In Python: x = 5. The name x refers to the value 5 until reassigned.",
              "questions": [
                {
                  "id": "cs_v_1",
                  "type": "mcq",
                  "difficulty": "easy",
                  "marks": 2,
                  "prompt": "Which line creates a variable named \"age\" with the value 18?",
                  "choices": [
                    "age == 18",
                    "age = 18",
                    "var age 18",
                    "int age"
                  ],
                  "answer": "age = 18"
                },
                {
                  "id": "cs_v_2",
                  "type": "code_output",
                  "difficulty": "medium",
                  "marks": 2,
                  "prompt": "What does this code print?",
                  "code": "x = 5\nx = x + 3\nprint(x)",
                  "language": "python",
                  "expectedOutput": "8",
                  "answer": "8"
                },
                {
                  "id": "cs_v_3",
                  "type": "tf",
                  "difficulty": "easy",
                  "marks": 1,
                  "prompt": "In Python, \"==\" assigns a value to a variable.",
                  "answer": false,
                  "explanation": "\"==\" tests equality. \"=\" is assignment."
                }
